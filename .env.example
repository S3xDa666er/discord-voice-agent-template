# Copy this file to ".env" and fill in your own values. Never commit .env.

# Discord bot token — Developer Portal > your app > Bot > Reset/Copy Token.
DISCORD_BOT_TOKEN=

# ElevenLabs API key — ElevenLabs > Profile > API Keys.
ELEVENLABS_API_KEY=

# ElevenLabs Conversational AI agent ID — Agents > your agent (looks like agent_xxxx…).
# Treat as a secret for a PUBLIC agent (anyone with it can use your credits).
ELEVENLABS_AGENT_ID=

# Comma-separated Discord user IDs allowed to use !join / talk to the bot.
# Leave EMPTY to allow EVERYONE in the server.   e.g.  123456789012345678,987654321098765432
DISCORD_ALLOWED_USERS=
